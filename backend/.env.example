PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:4200
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nursery_store
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Choose one SMTP style:
# 1. Provider shortcut, for example: Gmail or Outlook365
SMTP_SERVICE=Gmail
# 2. Or custom host/port values, for example Hostinger / cPanel / company SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=Nursery Store <your-email@example.com>
OTP_EXPIRES_MINUTES=10
