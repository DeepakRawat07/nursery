PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:4200
ALLOW_DEV_OTP_IN_PRODUCTION=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nursery_store
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Preferred on free Render: Resend over HTTPS
RESEND_API_KEY=
EMAIL_FROM=Nursery Store <onboarding@resend.dev>

# Optional SMTP fallback:
# 1. Provider shortcut, for example: Gmail or Outlook365
SMTP_SERVICE=
# 2. Or custom host/port values, for example Hostinger / cPanel / company SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=
OTP_EXPIRES_MINUTES=10
